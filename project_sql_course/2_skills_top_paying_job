/*Pregunta 2: Cuales son las habilidades requeridas para estos roles?
-   Utiliza los top-10 trabajos como Data Engineer mejores pagado como primera query
-   Anade las habilidades especificas requeridas para ese rol
- Por que? Te da una vista detallada de la demanda del skill para los trabajos que paguen mas,
ayudando a los buscadores de empleo a entender cuales habilidades desarrollar para que se alineen con esos salarios*/

WITH top_paying AS (SELECT
    job_id,
    job_title,
    job_location,
    salary_year_avg,
    name
FROM
    job_postings_fact as jobs
LEFT JOIN company_dim as companies ON
    jobs.company_id = companies.company_id
WHERE
    job_title_short = 'Data Engineer' AND
    salary_year_avg IS NOT NULL AND
    job_location = 'Anywhere'
)
SELECT
    s.skills,
    tp.*
FROM top_paying AS tp
INNER JOIN skills_job_dim AS js ON tp.job_id = js.job_id
INNER JOIN skills_dim AS s ON js.skill_id = s.skill_id
ORDER BY
    tp.salary_year_avg DESC
LIMIT 10;

