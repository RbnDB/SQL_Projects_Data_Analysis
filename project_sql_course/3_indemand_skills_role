/*Pregunta 3: Consigue las habilidades mas deseadas para ese rol
 -- En esta etapa del proyecto, en el curso se reutilizo un query
 que ya habiamos hecho pero yo no guarde. Vamos a recrearlo, este es el enunciado:
 Encuentra la cantidad de trabajos remoto por skill
  - Muestra los top 5 habilidades mas demandados en trabajos remotos.
  - Incluye skill ID, name, y la cantidad de publicaciones de trabajos requiriendo esa habilidad*/

WITH number_jobs_skills AS (
    SELECT
        COUNT(jp.*) AS skill_count,
        sj.skill_id
    FROM  
        skills_job_dim AS sj  
    INNER JOIN job_postings_fact AS jp ON sj.job_id = jp.job_id     
    WHERE
        jp.job_location = 'Anywhere' AND
        jp.job_title_short = 'Data Engineer'
    GROUP BY
        sj.skill_id
)

    SELECT 
    s.skill_id,
    s.skills,
    skill_count
FROM 
    number_jobs_skills AS n
INNER JOIN skills_dim AS s ON n.skill_id = s.skill_id
ORDER BY
    skill_count DESC;